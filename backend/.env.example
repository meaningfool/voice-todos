# Copy this file to backend/.env in each worktree before running extraction evals.
# `backend/.env` is gitignored and is not shared automatically between worktrees.

# Required for Gemini-based experiments.
GEMINI_API_KEY=

# Optional, but recommended if you want eval traces and spans sent to Logfire.
LOGFIRE_TOKEN=

# Required for the Mistral experiment, once the Mistral provider package is installed.
MISTRAL_API_KEY=
