# Local credential template for backend and eval development.
# Plain git worktrees do not share `backend/.env`, but this repo's Conductor setup
# symlinks `backend/.env` from the main checkout when it exists.
# Keep this file because it is the easiest visible contract for expected variables.

# Required for Gemini-based experiments.
GEMINI_API_KEY=

# Optional alternative to the CLI-managed credentials file at
# `backend/.logfire/logfire_credentials.json`.
LOGFIRE_TOKEN=

# Optional read token used for post-run Logfire artifact enrichment.
LOGFIRE_READ_TOKEN=

# Optional explicit project name. If omitted, runtime can fall back to
# `backend/.logfire/logfire_credentials.json`, but tests and scripts are easier
# to reason about when this is present.
LOGFIRE_PROJECT_NAME=

# Required for the Mistral experiment, once the Mistral provider package is installed.
MISTRAL_API_KEY=

# Required for the DeepInfra-backed Qwen 3.5 experiments.
DEEPINFRA_API_KEY=
